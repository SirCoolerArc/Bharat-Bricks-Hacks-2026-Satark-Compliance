# ─────────────────────────────────────────────
# SATARK Environment Variables
# Copy to .env.local and fill in your values
# ─────────────────────────────────────────────

# Databricks SQL Warehouse connection
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi_your_token_here
DATABRICKS_WAREHOUSE_ID=your_warehouse_id

# Databricks catalog / schema for Gold tables
DATABRICKS_CATALOG=satark
DATABRICKS_SCHEMA=gold

# Databricks Model Serving (RAG chatbot)
DATABRICKS_SERVING_ENDPOINT=https://your-workspace.cloud.databricks.com/serving-endpoints/satark-rag/invocations

# ONNX model path (relative to web/ root)
ONNX_MODEL_PATH=./models/fraud_scorer.onnx

# App settings
NEXT_PUBLIC_APP_NAME=SATARK
NODE_ENV=development
